Proceso InteresSimple

    Definir capital, tasa, tiempo, interes Como Real

    tasa <- 0.05

    Escribir "La tasa de interés es: ", tasa * 100, "%"

    Escribir "Ingresá el capital:"
    Leer capital

    Escribir "Ingresá el tiempo (en años):"
    Leer tiempo

    interes <- capital * tasa * tiempo

    Escribir "El interés simple es: ", interes

FinProceso